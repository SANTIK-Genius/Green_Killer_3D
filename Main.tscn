[sub_resource type="Shader" id="20"]
code = "shader_type canvas_item;
uniform sampler2D screen_tex : hint_screen_texture, repeat_disable, filter_linear_mipmap;
uniform float vignette_strength : hint_range(0.0, 1.0) = 0.78;
uniform float blur_strength : hint_range(0.0, 1.0) = 0.0;
void fragment() {
	vec2 uv = SCREEN_UV;
	vec2 center = vec2(0.5);
	float dist = distance(uv, center);
	vec2 blur = normalize(uv - center) * 0.003 * blur_strength;
	vec4 col = textureLod(screen_tex, uv, 0.0);
	col += textureLod(screen_tex, uv + blur, 0.0);
	col += textureLod(screen_tex, uv - blur, 0.0);
	col /= 3.0;
	float vignette = smoothstep(0.15, 0.78, dist);
	col.rgb *= 1.0 - vignette * vignette_strength;
	COLOR = col;
}"

